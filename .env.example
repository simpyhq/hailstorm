# Environment variables for the Vercel serverless functions in /api.
# Copy to `.env` for local `vercel dev`, and set the same keys in your Vercel
# project (Settings -> Environment Variables) for production.
#
# These were previously HARDCODED in client code and are now exposed in git
# history — ROTATE them before setting the new values here.

# Canvas LMS API token (OU). Generate a new one in Canvas: Account ->
# Settings -> New Access Token. Used by /api/canvas-events.
CANVAS_TOKEN=

# SimplyHQ portal password. Used by /api/simplyhq for email + jobs.
SIMPLYHQ_PASSWORD=

# --- Voice (Phase 2) ---
# Premium TTS for the voice loop. Either provider works; if neither is set,
# /api/tts returns 503 and the HUD falls back to the browser's built-in
# speechSynthesis (works but lower quality).

# ElevenLabs (preferred — better "Jarvis" voice). Get a key at elevenlabs.io.
ELEVENLABS_API_KEY=
# Optional: override the default voice. Default = "Adam" (pNInz6obpgDQGcFmaJgB).
# Pick another from https://api.elevenlabs.io/v1/voices.
ELEVENLABS_VOICE_ID=

# OpenAI TTS — used as fallback if ELEVENLABS_API_KEY is unset.
OPENAI_API_KEY=
# Optional: alloy, echo, fable, onyx (default — closest to Jarvis), nova, shimmer.
OPENAI_TTS_VOICE=

# --- Brain (OpenClaw via /api/chat) ---
# Full URL that accepts POST { message, session_id } and returns { reply }.
# Works with the FastAPI backend (point at its /chat) or OpenClaw directly.
# If neither this nor OPENCLAW_API_URL is set, /api/chat returns 503 and the
# HUD falls back to its canned router (HUD-data answers + tab/brief commands).
JARVIS_BRAIN_URL=
# Convenience alternative — /api/chat will call ${OPENCLAW_API_URL}/api/chat.
OPENCLAW_API_URL=
# Optional bearer token, sent as Authorization header to the brain endpoint.
JARVIS_BRAIN_TOKEN=
